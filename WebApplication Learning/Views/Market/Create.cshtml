@model ProductModel
@{
    ViewData["Title"] = "Market";
}

    <div class="text-center">
        <h1 class="display-4">Create a Product</h1>
    </div>

    <form asp-controller="Product" asp-action="Create" method="post">

        <div class="form-group">
            <label for="productName">Name</label>
            <input type="text" asp-for="Name" class="form-control" placeholder="Enter product name">
        </div>

        <div class="form-group">
            <label for="productPrice">Price</label>
            <input type="number" step="0.01" asp-for="Price" class="form-control" placeholder="Enter product price">
        </div>

        <button type="submit" class="btn btn-primary">Submit</button>
        <a class="btn btn-secondary btn-block" asp-controller="Market" asp-action="Index" role="button">Voltar</a>

    </form>
