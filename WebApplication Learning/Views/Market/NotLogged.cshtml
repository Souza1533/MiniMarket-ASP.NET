@{
    ViewData["Title"] = "You Need an account";
}

<div class="text-center mt-5">
    <div class="display-1 text-danger"><i class="bi bi-shield-lock"></i></div>
    <h1 class="display-4">Oops! Restricted Access</h1>
    <p class="lead">You need to be logged in to manage the Mini-Market inventory.</p>
    <hr class="my-4">
    <p>Click the button below to log in to your account.</p>
    <a class="btn btn-primary btn-lg" asp-controller="Home" asp-action="index" role="button">Login</a>
    <a class="btn btn-outline-secondary btn-lg" asp-controller="Home" asp-action="Index" role="button">Back to homepage</a>
</div>