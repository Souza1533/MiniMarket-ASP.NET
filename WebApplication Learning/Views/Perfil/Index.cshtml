@using Microsoft.AspNetCore.Http
@model AccountModel

@{
    ViewData["Title"] = "Register Account";
}

@if (Context.Session.GetString("IsLoggedIn") == "true")
{
    <h2 class="text-center">You are already logged in</h2>
}

else
{
    <div class="text-center">
        <h1 class="display-4">Create your Account</h1>
        <p>Join the mini-market system</p>
    </div>

    <div class="row justify-content-center">
        <div class="col-md-4">
            <form asp-controller="Account" asp-action="Add" method="post">
                <div class="form-group mb-3">
                    <label asp-for="Name">Full Name</label>
                    <input type="text" asp-for="Name" class="form-control" placeholder="Enter your name">
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="Age">Age</label>
                    <input type="number" asp-for="Age" class="form-control" placeholder="Your age">
                    <span asp-validation-for="Age" class="text-danger"></span>
                </div>

                <button type="submit" class="btn btn-primary btn-block w-100">Register</button>
                <a class="btn btn-outline-secondary w-100 mt-2" asp-controller="Perfil" asp-action="Edit">Back to Home</a>

            </form>
        </div>
    </div>
}
