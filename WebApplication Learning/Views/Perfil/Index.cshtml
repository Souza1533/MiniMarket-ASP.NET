@using Microsoft.AspNetCore.Http
@model AccountModel

@{
    ViewData["Title"] = "Register Account";
}

@if (Context.Session.GetString("IsLoggedIn") == "true")
{
    <div class="container mt-5">
        <h2>About Me</h2>
        <hr />
        <ul class="list-group">
            <li class="list-group-item"><strong>ID:</strong> @Model.Id</li>
            <li class="list-group-item"><strong>Name:</strong> @Model.Name</li>
            <li class="list-group-item"><strong>Age:</strong> @Model.Age</li>
        </ul>
        <div class="mt-3">
            <a asp-controller="Home" asp-action="Index" class="btn btn-primary">Voltar para Home</a>
        </div>
    </div>
}

else
 
{
<div class="text-center">
        <h1 class="display-4">Create your Account</h1>
        <p>Join the mini-market system</p>
    </div>

    <div class="row justify-content-center">
        <div class="col-md-4">
            <form asp-controller="Account" asp-action="Register" method="post">
                <div class="form-group mb-3">
                    <label asp-for="Name">Full Name</label>
                    <input type="text" asp-for="Name" class="form-control" placeholder="Enter your name">
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="Age">Age</label>
                    <input type="number" asp-for="Age" class="form-control" placeholder="Your age">
                    <span asp-validation-for="Age" class="text-danger"></span>
                </div>

                <button type="submit" class="btn btn-primary btn-block w-100">Register</button>
                <a class="btn btn-outline-secondary w-100 mt-2" asp-controller="Home" asp-action="Index">Back to Home</a>

            </form>
        </div>
    </div>
}



